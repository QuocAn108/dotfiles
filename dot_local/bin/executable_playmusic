#!/usr/bin/env bash

mkdir -p "$HOME/.config/mpd/playlists"

SOURCE=$(echo -e "1. YouTube\n2. SoundCloud\n3. Spotify (Cào qua YouTube)" | fzf --prompt="Chọn nguồn nhạc: " | awk '{print $2}')

if [ -z "$SOURCE" ]; then
    echo "Đã hủy."
    exit 0
fi

read -p "Nhập tên bài hát / URL cần tìm: " QUERY

if [ -z "$QUERY" ]; then
    echo "Từ khóa trống!"
    exit 1
fi

case "$SOURCE" in
    "YouTube")
        echo "Đang tìm trên YouTube..."
        ytfzf -m "$QUERY"
        ;;
    "SoundCloud")
        echo "Đang tìm trên SoundCloud..."
        URL=$(yt-dlp "scsearch1:$QUERY" --get-url --skip-download --ext mp3 2>/dev/null)
        if [ ! -z "$URL" ]; then
            mpc add "$URL"
            mpc play
            echo "Đã thêm vào RMPC!"
        else
            echo "Khong tim thay kết quả trên SoundCloud."
        fi
        ;;
    "Spotify")
        echo "Đang giả lập tìm kiếm Spotify qua YouTube..."
        ytfzf -m "$QUERY audio"
        ;;
esac
