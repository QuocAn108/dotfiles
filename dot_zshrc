# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"
# # Alias cho Neovim
alias nv='nvim'
alias vi='nvim'
alias vim='nvim'
alias nz='nvim .zshrc'

#Alias Zellij
alias za='zellij attach || zellij'
alias zl='zellij list-sessions'

# Alias hệ thống
alias ...='cd ../..'
alias update='paru -Syu'
alias c='clear'
alias e='exit'
alias sz='source .zshrc'
alias ff='fastfetch'
# Dùng eza thay cho ls (hiện icon, màu đẹp)
alias ls='eza --icons --group-directories-first'
alias ll='eza -lh --icons --group-directories-first'

# Dùng bat thay cho cat (có highlight code)
alias cat='bat'

# Kích hoạt zoxide (thay thế cd - nó tự nhớ thư mục hay vào)
eval "$(zoxide init zsh)"

# Alias for chezmoi 
alias ca="chezmoi add"
alias cgc="chezmoi git -- commit -am"
alias cgp="chezmoi git -- push"

# Docker Aliases (Gõ nhanh tiết kiệm thời gian)
alias d='docker'
alias dc='docker-compose'
alias dcu='docker-compose up -d'
alias dcd='docker-compose down'
alias dcl='docker logs -f'
alias ld='lazydocker'

# Git Aliases siêu tốc
alias ga='git add'
alias gaa='git add .'
alias gcm='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gs='git status'
alias gd='git diff'

# Monitor phần cứng
alias nvtop='nvtop' # Giao diện xem GPU cực đẹp
alias vram='watch -n 0.5 nvidia-smi' # Đổi tên từ gpu thành vram để tránh trùng với git push của Oh My Zsh

# Rmpc YouTube/SoundCloud search aliases
alias syt='rmpc searchyt -i'
alias ssc='rmpc searchyt --provider soundcloud -i'

#alias reset dải màu
alias fixdisp='kscreen-doctor output.HDMI-A-1.disable && sleep 1 && kscreen-doctor output.HDMI-A-1.enable'

# Kích hoạt FZF tìm kiếm siêu tốc (Đặt trước khi chạy exec zellij)
if command -v fzf >/dev/null 2>&1; then
    source <(fzf --zsh)
fi


# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# Tự động chạy Zellij một cách an toàn nếu đang ở interactive shell
if [ -z "$ZELLIJ" ] && [ "$ZSH_EVAL_CONTEXT" = "toplevel" ]; then
    if zellij list-sessions 2>/dev/null | grep -q -v "EXITED"; then
        # Nếu có session cũ đang chạy ngầm, hỏi ông có muốn kết nối lại không
        exec zellij attach $(zellij list-sessions | grep -v "EXITED" | head -n 1 | awk '{print $1}')
    else
        # Nếu không có session nào, tạo mới
        exec zellij
    fi
fi

export JDTLS_JVM_ARGS="-javaagent:$HOME/.local/share/nvim/mason/packages/jdtls/lombok.jar"
export EDITOR="nvim"
export VISUAL="nvim"
[ -f ~/.env.local ] && source ~/.env.local
